{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.corpollc/corpo-mcp",
  "description": "MCP server for AI agent entity formation — form and govern Wyoming DAO LLCs. 16 tools for entity formation, governance actions, director marketplace, compliance tracking.",
  "repository": {
    "url": "https://github.com/corpollc/corpo-mcp",
    "source": "github"
  },
  "version": "0.1.0",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "corpo-mcp",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Corpo API base URL",
          "name": "CORPO_API_URL",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        },
        {
          "description": "Corpo API authentication token",
          "name": "CORPO_API_TOKEN",
          "isRequired": false,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ]
}
